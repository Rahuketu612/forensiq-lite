# ===========================================
# ForensiQ Lite - Development Environment
# ===========================================

# ===========================================
# PORT ARCHITECTURE
# ===========================================
# Frontend (Next.js): 3000
# Backend API (NestJS): 3001
# PostgreSQL: 5432
# Future AI Service: 3002
# Future Worker/Queue: 3003
# Future OCR/Parser Service: 3004
# ===========================================

# Application
NODE_ENV=development

# API Service (NestJS)
API_PORT=3001
API_PREFIX=api

# Frontend URL (used by backend for CORS and by frontend for API calls)
NEXT_PUBLIC_API_URL=http://localhost:3001

# ===========================================
# DEV AUTH BYPASS (for local development only)
# ===========================================
# Set to true to skip login and auto-use demo auditor
# NEVER enable in production!
DEV_AUTH_BYPASS=false

# ===========================================
# Database (PostgreSQL)
# ===========================================
DATABASE_URL=postgresql://forensiq:forensiq_secure_password@localhost:5432/forensiq?schema=public&sslmode=prefer

# PostgreSQL Connection
POSTGRES_USER=forensiq
POSTGRES_PASSWORD=forensiq_secure_password
POSTGRES_DB=forensiq
POSTGRES_PORT=5432
POSTGRES_HOST=localhost

# CORS - Single origin for local development
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# ===========================================
# FUTURE SERVICES (Reserved)
# ===========================================
# AI Service - Local AI assistance
# AI_PORT=3002

# Worker Service - Background jobs
# WORKER_PORT=3003

# OCR/Parser Service - Document processing
# OCR_PORT=3004