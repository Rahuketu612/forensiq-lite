// ForensiQ Lite - Prisma Database Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  AUDITOR
  VIEWER
}

enum CaseStatus {
  DRAFT
  ACTIVE
  UNDER_REVIEW
  CLOSED
}

enum TransactionType {
  CREDIT
  DEBIT
  TRANSFER
  REFUND
  FEE
  OTHER
}

enum TransactionMode {
  CASH
  CHEQUE
  NEFT
  RTGS
  UPI
  IMPS
  ONLINE
  CARD
  BANK
  OTHER
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  NEEDS_MANUAL_MAPPING
  MAPPING_CONFIRMED
  EXTRACTED_TEXT
  OCR_PENDING
  OCR_PROCESSING
  OCR_COMPLETED
  OCR_FAILED
}

enum RedFlagSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum InvestigationStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  FALSE_POSITIVE
}

enum TimelineEventType {
  FLAG_CREATED
  FLAG_REVIEWED
  FLAG_STATUS_CHANGED
  FLAG_FEEDBACK_ADDED
  NOTE_ADDED
  EVIDENCE_UPLOADED
  EVIDENCE_LINKED
  EVIDENCE_DELETED
  TRANSACTION_IMPORTED
  TRANSACTION_EXAMINED
  FUND_TRAIL_GENERATED
  FUND_TRAIL_PATTERNS_ANALYZED
  TRANSACTION_LINK_CREATED
  TRANSACTION_LINK_DELETED
  PATTERN_DETECTED
  PATTERN_REVIEWED
  PATTERN_STATUS_CHANGED
  ENTITY_ANALYSIS_COMPLETED
  GRAPH_GENERATED
}

enum LinkReason {
  SAME_AMOUNT
  NEARBY_TIMESTAMP
  SAME_COUNTERPARTY
  NARRATION_SIMILARITY
  SAME_MODE
  SAME_TYPE
  ROUND_AMOUNT
  SUSPICIOUS_PATTERN
}

enum PatternType {
  CIRCULAR_FLOW
  LAYERING
  ROUND_TRIPPING
  REPEATED_CHAIN
}

enum AuditAction {
  CREATED
  UPDATED
  DELETED
  READ
  LINK_CREATED
  LINK_DELETED
  TRAIL_GENERATED
  PATTERN_DETECTED
  PATTERN_REVIEWED
  PATTERN_STATUS_CHANGED
  EXPORTED
}

model User {
  id                  String    @id @default(uuid())
  email               String    @unique
  name                String
  password            String
  role                UserRole  @default(AUDITOR)
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  passwordResetToken  String?
  passwordResetExpires DateTime?
  lastLoginAt         DateTime?
  lastLoginIp         String?

  casesCreated        Case[]                @relation("CreatedCases")
  casesAssigned       Case[]                @relation("AssignedCases")
  transactionImports  TransactionImport[]
  
  redFlagFeedbacks    RedFlagFeedback[]
  investigationNotes  InvestigationNote[]
  evidenceFiles       EvidenceFile[]
  timelines           InvestigationTimeline[]
  auditLogs           AuditLog[]
  transactionLinksCreated TransactionLink[]   @relation("LinkCreator")
  transactionLinksDeleted TransactionLink[]   @relation("LinkDeleter")
  fundTrailPatternsCreated FundTrailPattern[] @relation("PatternCreator")
  aiAnalyses          AiAnalysis[]

  @@index([email])
}

model AuditLog {
  id            String      @id @default(uuid())
  userId        String?
  action        AuditAction
  entityType    String
  entityId      String
  caseId        String?
  metadata      Json?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime    @default(now())

  user          User?       @relation(fields: [userId], references: [id])

  @@index([caseId])
  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
}

model Case {
  id              String     @id @default(uuid())
  caseNumber      String     @unique
  title           String
  description     String?
  status          CaseStatus @default(DRAFT)
  riskLevel       RiskLevel?
  clientName      String?
  clientEmail     String?
  clientPhone     String?
  clientAddress   String?
  assignedToId    String?
  assignedAt      DateTime?
  createdById     String
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  completedAt     DateTime?

  createdBy       User       @relation("CreatedCases", fields: [createdById], references: [id])
  assignedTo      User?      @relation("AssignedCases", fields: [assignedToId], references: [id])
  
  transactionImports TransactionImport[]
  transactions    Transaction[]
  redFlagRules   RedFlagRule[]
  redFlags       RedFlag[]
  investigationNotes InvestigationNote[]
  evidenceFiles  EvidenceFile[]
  timelines      InvestigationTimeline[]
  transactionLinks TransactionLink[]
  fundTrailPatterns FundTrailPattern[]
  entities       Entity[]
  graphNodes     GraphNode[]
  graphEdges     GraphEdge[]
  graphAuditLogs GraphAuditLog[]
  aiAnalyses     AiAnalysis[]

  @@index([caseNumber])
  @@index([status])
  @@index([createdById])
}

model TransactionImport {
  id               String       @id @default(uuid())
  caseId           String
  fileName         String
  originalName     String
  mimeType         String
  importedById     String
  importedAt       DateTime     @default(now())
  status           ImportStatus @default(PENDING)
  totalRows        Int          @default(0)
  successRows      Int          @default(0)
  failedRows       Int          @default(0)
  errorLog         Json?
  hasText          Boolean      @default(false)
  extractedText    String?
  isScanned        Boolean      @default(false)
  ocrText          String?
  ocrConfidence    Float?
  ocrCompletedAt   DateTime?
  mappingConfig    Json?
  mappedBy         String?
  mappedAt         DateTime?

  case             Case         @relation(fields: [caseId], references: [id], onDelete: Cascade)
  importedBy       User         @relation(fields: [importedById], references: [id])
  transactions     Transaction[]

  @@index([caseId])
  @@index([status])
}

model Transaction {
  id              String           @id @default(uuid())
  importId        String
  caseId          String
  date            DateTime
  description     String?
  amount          Float
  type            TransactionType
  balance         Float?
  counterparty    String?
  mode            TransactionMode  @default(OTHER)
  referenceNumber String?
  rowNumber       Int?
  rawData         Json?
  riskScore       Float            @default(0)
  riskFactors     String[]         @default([])
  
  // Additional entity resolution fields stored in rawData
  gstin           String?
  pan             String?
  bankAccount     String?
  ifsc            String?
  upiId           String?
  phone           String?
  
  createdAt       DateTime         @default(now())

  import          TransactionImport @relation(fields: [importId], references: [id], onDelete: Cascade)
  case            Case              @relation(fields: [caseId], references: [id], onDelete: Cascade)
  
  redFlags        RedFlag[]
  investigationNotes InvestigationNote[]
  evidenceFiles   EvidenceFile[]
  timelines       InvestigationTimeline[]
  linksAsSource   TransactionLink[] @relation("SourceTransaction")
  linksAsTarget   TransactionLink[] @relation("TargetTransaction")
  entityLinks     TransactionEntity[]
  entityAliases   EntityAlias[]

  @@index([caseId])
  @@index([importId])
  @@index([date])
  @@index([type])
}

model TransactionLink {
  id                 String      @id @default(uuid())
  caseId             String
  sourceTransactionId String
  targetTransactionId String
  linkReason         LinkReason
  confidenceScore    Float
  
  explanation        String

  amountMatch        Boolean?
  timestampMatch     Boolean?
  counterpartyMatch  Boolean?
  narrationMatch     Boolean?
  
  amountDifference   Float?
  timeDifferenceMs   Int?
  narrationSimilarity Float?
  
  createdById        String
  createdAt          DateTime    @default(now())
  deletedAt          DateTime?
  deletedById        String?

  case               Case        @relation(fields: [caseId], references: [id], onDelete: Cascade)
  sourceTransaction  Transaction @relation("SourceTransaction", fields: [sourceTransactionId], references: [id], onDelete: Cascade)
  targetTransaction  Transaction @relation("TargetTransaction", fields: [targetTransactionId], references: [id], onDelete: Cascade)
  createdBy          User        @relation("LinkCreator", fields: [createdById], references: [id])
  deletedBy          User?       @relation("LinkDeleter", fields: [deletedById], references: [id])

  @@index([caseId])
  @@index([sourceTransactionId])
  @@index([targetTransactionId])
  @@index([linkReason])
  @@index([confidenceScore])
  @@index([createdAt])
}

model RedFlagRule {
  id            String     @id @default(uuid())
  caseId        String
  name          String
  description   String
  isActive      Boolean    @default(true)
  priority      Int        @default(0)
  parameters    Json?
  conditionType String?
  conditionValue String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  case          Case       @relation(fields: [caseId], references: [id], onDelete: Cascade)
  redFlags      RedFlag[]

  @@index([caseId])
}

model RedFlag {
  id           String             @id @default(uuid())
  caseId       String
  ruleId       String?
  ruleName     String
  transactionId String
  title        String
  explanation  String
  severity     RedFlagSeverity    @default(MEDIUM)
  status       InvestigationStatus @default(OPEN)
  reviewed     Boolean            @default(false)
  reviewedBy   String?
  reviewedAt   DateTime?
  feedbackType String?
  feedbackNote String?
  feedbackById String?
  feedbackAt   DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  case         Case               @relation(fields: [caseId], references: [id], onDelete: Cascade)
  rule         RedFlagRule?       @relation(fields: [ruleId], references: [id])
  transaction  Transaction        @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  feedbacks    RedFlagFeedback[]
  investigationNotes InvestigationNote[]
  evidenceFiles EvidenceFile[]
  timelines    InvestigationTimeline[]

  @@index([caseId])
  @@index([transactionId])
  @@index([severity])
  @@index([status])
}

model RedFlagFeedback {
  id         String   @id @default(uuid())
  redFlagId  String
  type       String
  note       String?
  userId     String
  createdAt  DateTime @default(now())

  redFlag    RedFlag  @relation(fields: [redFlagId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id])

  @@index([redFlagId])
  @@index([userId])
}

model InvestigationNote {
  id            String    @id @default(uuid())
  caseId        String
  title         String
  content       String
  authorId      String
  transactionId String?
  redFlagId     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  case          Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  author        User      @relation(fields: [authorId], references: [id])
  transaction   Transaction? @relation(fields: [transactionId], references: [id])
  redFlag       RedFlag?  @relation(fields: [redFlagId], references: [id])

  @@index([caseId])
  @@index([authorId])
  @@index([transactionId])
  @@index([redFlagId])
}

model EvidenceFile {
  id            String    @id @default(uuid())
  caseId        String
  fileName      String
  originalName  String
  mimeType      String
  size          Int
  path          String
  hash          String
  description   String?
  category      String?
  transactionId String?
  redFlagId     String?
  uploadedById  String
  uploadedAt    DateTime  @default(now())

  case          Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  transaction   Transaction? @relation(fields: [transactionId], references: [id])
  redFlag       RedFlag?  @relation(fields: [redFlagId], references: [id])
  uploadedBy    User      @relation(fields: [uploadedById], references: [id])

  @@index([caseId])
  @@index([transactionId])
  @@index([redFlagId])
}

model InvestigationTimeline {
  id           String             @id @default(uuid())
  caseId       String
  redFlagId    String?
  transactionId String?
  patternId    String?
  eventType    TimelineEventType
  title        String
  description  String?
  userId       String
  metadata     Json?
  createdAt    DateTime           @default(now())

  case         Case               @relation(fields: [caseId], references: [id], onDelete: Cascade)
  redFlag      RedFlag?           @relation(fields: [redFlagId], references: [id])
  transaction  Transaction?      @relation(fields: [transactionId], references: [id])
  user         User               @relation(fields: [userId], references: [id])
  pattern      FundTrailPattern?  @relation(fields: [patternId], references: [id])

  @@index([caseId])
  @@index([redFlagId])
  @@index([transactionId])
  @@index([patternId])
  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
}

model FundTrailPattern {
  id               String           @id @default(uuid())
  caseId           String
  patternType      PatternType
  title            String
  explanation      String
  confidenceScore  Float
  totalAmount      Float?
  
  transactionIds   String[]
  counterparties   String[]
  
  timeWindowStart  DateTime?
  timeWindowEnd    DateTime?
  
  reviewed        Boolean          @default(false)
  reviewedBy      String?
  reviewedAt      DateTime?
  status          InvestigationStatus @default(OPEN)
  
  createdById      String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  createdBy       User             @relation("PatternCreator", fields: [createdById], references: [id])
  case            Case             @relation(fields: [caseId], references: [id], onDelete: Cascade)
  timelines       InvestigationTimeline[]

  @@index([caseId])
  @@index([patternType])
  @@index([status])
  @@index([reviewed])
  @@index([createdAt])
}

// Entity Resolution Models
// Explains how counterparties are matched and clustered

enum MatchType {
  EXACT_NAME
  NORMALIZED_NAME
  GSTIN
  PAN
  BANK_ACCOUNT
  IFSC
  UPI_ID
  PHONE
}

model Entity {
  id              String    @id @default(uuid())
  caseId          String
  canonicalName   String    // The canonical/primary name for this entity
  riskScore       Float     @default(0)
  totalAmount     Float     @default(0)
  transactionCount Int      @default(0)
  reviewed        Boolean   @default(false)
  reviewedBy      String?
  reviewedAt      DateTime?
  explanation     String?   // Human-readable explanation of entity resolution
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  case            Case            @relation(fields: [caseId], references: [id], onDelete: Cascade)
  aliases         EntityAlias[]
  transactions    TransactionEntity[]
  auditLogs       EntityAuditLog[]

  @@index([caseId])
  @@index([canonicalName])
  @@index([riskScore])
  @@index([reviewed])
  @@index([createdAt])
}

model EntityAlias {
  id              String    @id @default(uuid())
  entityId        String
  aliasName       String    // The alternative name/identifier
  matchType       MatchType // How this alias was matched
  source          String?   // Source of the alias (e.g., "counterparty", "beneficiary")
  confidenceScore Float     // Confidence of the match (0-1)
  matchReason     String?   // Human-readable reason for the match
  transactionId   String?   // Which transaction introduced this alias
  createdAt       DateTime  @default(now())

  entity          Entity            @relation(fields: [entityId], references: [id], onDelete: Cascade)
  transaction     Transaction?      @relation(fields: [transactionId], references: [id])
  auditLogs       EntityAliasAuditLog[]

  @@index([entityId])
  @@index([aliasName])
  @@index([matchType])
  @@index([confidenceScore])
}

// Junction table for Transaction-Entity many-to-many relationship
model TransactionEntity {
  id              String    @id @default(uuid())
  transactionId   String
  entityId        String
  role            String    @default("counterparty") // counterparty, beneficiary, sender, receiver
  matchScore      Float     @default(1.0)
  createdAt       DateTime  @default(now())

  transaction     Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  entity          Entity      @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([transactionId, entityId, role])
  @@index([transactionId])
  @@index([entityId])
}

// Entity resolution audit log - tracks all decisions made by the algorithm
model EntityAuditLog {
  id              String    @id @default(uuid())
  entityId        String
  action          String    // ANALYZE, CREATE, MERGE, SPLIT, UPDATE, REVIEW
  description     String    // Human-readable description of the action
  confidenceScore Float?
  matchDetails    Json?     // Details about how entities were matched
  affectedAliases Json?     // List of affected alias IDs
  previousState   Json?     // State before the action
  newState        Json?     // State after the action
  triggeredBy     String?   // "system" or userId
  createdAt       DateTime  @default(now())

  entity          Entity    @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@index([entityId])
  @@index([action])
  @@index([createdAt])
}

// Individual alias audit log
model EntityAliasAuditLog {
  id              String    @id @default(uuid())
  aliasId         String
  action          String    // ADDED, REMOVED, MERGED, UPDATED
  description     String
  previousEntityId String?
  newEntityId     String?
  reason          String?
  createdAt       DateTime  @default(now())

  alias           EntityAlias @relation(fields: [aliasId], references: [id], onDelete: Cascade)

  @@index([aliasId])
  @@index([createdAt])
}

// =============================================================================
// GRAPH MODELS - Investigation Relationship Graph
// =============================================================================

enum NodeType {
  ENTITY
  GSTIN
  PAN
  BANK_ACCOUNT
  IFSC
  PHONE
  UPI
  ADDRESS
  EMAIL
}

enum EdgeType {
  OWNS
  USES
  SHARES_PHONE
  SHARES_GSTIN
  SHARES_BANK_ACCOUNT
  SHARES_UPI
  SHARES_ADDRESS
  SHARES_EMAIL
  TRANSACTED_WITH
  RELATED_TO
}

// GraphNode - Represents any node in the investigation graph
model GraphNode {
  id          String    @id @default(uuid())
  caseId      String
  nodeType    NodeType
  label       String
  externalId  String?   // Link to external entity (Entity, Transaction, etc.)
  riskScore   Int       @default(0)
  metadata    Json?     // Additional node data
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  case        Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  
  // Outgoing edges (as source)
  edgesFrom   GraphEdge[] @relation("EdgeSource")
  
  // Incoming edges (as target)
  edgesTo     GraphEdge[] @relation("EdgeTarget")

  @@index([caseId])
  @@index([nodeType])
  @@index([label])
  @@index([externalId])
}

// GraphEdge - Represents relationships between nodes
model GraphEdge {
  id              String    @id @default(uuid())
  caseId          String
  sourceNodeId    String
  targetNodeId    String
  edgeType        EdgeType
  confidenceScore Float     @default(0)  // 0.0 - 1.0
  explanation     String    // Human-readable explanation
  evidenceCount   Int       @default(0)
  metadata        Json?     // Additional edge data (transaction IDs, amounts, etc.)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  case            Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  sourceNode      GraphNode @relation("EdgeSource", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNode      GraphNode @relation("EdgeTarget", fields: [targetNodeId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([edgeType])
  @@index([sourceNodeId])
  @@index([targetNodeId])
  @@index([confidenceScore])
}

// Graph generation audit log
model GraphAuditLog {
  id            String    @id @default(uuid())
  caseId        String
  action        String    // GENERATED, REFRESHED, NODE_ADDED, NODE_REMOVED, EDGE_ADDED, EDGE_REMOVED
  description   String
  nodeCount     Int?
  edgeCount     Int?
  details       Json?     // Additional metadata
  triggeredBy   String    @default("system")  // "system" or userId
  createdAt     DateTime  @default(now())

  case          Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([action])
  @@index([createdAt])
}

// =============================================================================
// AI ANALYSIS MODELS - Audit Trail for AI Investigation Assistant
// =============================================================================

enum AnalysisType {
  SUMMARY
  TIMELINE
  QUESTIONS
  EVIDENCE_GAPS
  FULL_ANALYSIS
}

model AiAnalysis {
  id           String       @id @default(uuid())
  caseId       String
  analysisType AnalysisType
  prompt       String       @db.Text
  response     String       @db.Text
  modelName    String
  tokenCount   Int?
  duration     Int?         // Duration in milliseconds
  createdAt    DateTime     @default(now())
  createdById  String

  case         Case         @relation(fields: [caseId], references: [id], onDelete: Cascade)
  createdBy    User         @relation(fields: [createdById], references: [id])

  @@index([caseId])
  @@index([analysisType])
  @@index([createdAt])
  @@index([createdById])
}
