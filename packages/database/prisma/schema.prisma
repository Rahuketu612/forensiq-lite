// ForensiQ Lite - Prisma Database Schema
// MVP Architecture - Simplified & Clean

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  ADMIN
  AUDITOR
  VIEWER
}

enum CaseStatus {
  DRAFT
  ACTIVE
  UNDER_REVIEW
  CLOSED
}

enum TransactionType {
  CREDIT
  DEBIT
  TRANSFER
  REFUND
  FEE
  OTHER
}

enum TransactionMode {
  CASH
  CHEQUE
  NEFT
  RTGS
  UPI
  IMPS
  ONLINE
  CARD
  BANK
  OTHER
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  
  // PDF Processing
  EXTRACTED_TEXT       // PDF text extracted, awaiting mapping
  NEEDS_MANUAL_MAPPING // Columns could not be auto-detected
  
  // OCR Status
  OCR_PENDING
  OCR_PROCESSING
  OCR_COMPLETED
  OCR_FAILED
}

enum RedFlagSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ReviewStatus {
  PENDING
  REVIEWED
  DISMISSED
}

enum FeedbackType {
  IMPORTANT
  FALSE_POSITIVE
  NEEDS_EVIDENCE
  IGNORE
}

enum InvestigationStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  FALSE_POSITIVE
}

enum TimelineEventType {
  // Red flag events
  FLAG_CREATED
  FLAG_REVIEWED
  FLAG_STATUS_CHANGED
  FLAG_FEEDBACK_ADDED
  
  // Investigation events
  NOTE_ADDED
  EVIDENCE_UPLOADED
  EVIDENCE_LINKED
  EVIDENCE_DELETED
  
  // Transaction events
  TRANSACTION_IMPORTED
  TRANSACTION_EXAMINED
}

// ============================================
// MODELS
// ============================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      UserRole @default(AUDITOR)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Auth
  passwordResetToken  String?
  passwordResetExpires DateTime?
  lastLoginAt DateTime?
  lastLoginIp String?

  // Relations
  cases            Case[]            @relation("CreatedCases")
  assignedCases    Case[]            @relation("AssignedCases")
  redFlags         RedFlag[]
  redFlagFeedback  RedFlagFeedback[]
  notes            InvestigationNote[]
  evidenceFiles    EvidenceFile[]

  @@index([email])
}

model Case {
  id          String     @id @default(cuid())
  caseNumber  String     @unique
  title       String
  description String?
  status      CaseStatus @default(DRAFT)
  riskLevel   RiskLevel?

  // Client
  clientName    String?
  clientEmail   String?
  clientPhone   String?
  clientAddress String?

  // Assignment
  assignedToId String?
  assignedTo   User?  @relation("AssignedCases", fields: [assignedToId], references: [id])
  assignedAt   DateTime?

  // Audit Trail
  createdBy   User   @relation("CreatedCases", fields: [createdById], references: [id])
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  completedAt DateTime?

  // Relations
  transactions   TransactionImport[]
  redFlags      RedFlag[]
  redFlagRules  RedFlagRule[]
  notes         InvestigationNote[]
  evidenceFiles EvidenceFile[]

  @@index([caseNumber])
  @@index([status])
  @@index([createdById])
}

model TransactionImport {
  id        String   @id @default(cuid())
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)

  // Import reference
  fileName     String
  originalName String
  mimeType    String
  importedBy   User   @relation(fields: [importedById], references: [id])
  importedById String
  importedAt   DateTime @default(now())

  // Status
  status      ImportStatus @default(PENDING)
  totalRows   Int @default(0)
  successRows Int @default(0)
  failedRows  Int @default(0)
  errorLog    Json?

  // PDF/OCR Processing
  hasText       Boolean @default(false)     // PDF has selectable text
  extractedText String?                     // Raw extracted text from PDF
  isScanned     Boolean @default(false)     // PDF is scanned (needs OCR)
  
  // OCR Results
  ocrText        String?
  ocrConfidence  Float?                     // 0-100 confidence score
  ocrCompletedAt DateTime?

  // Relations
  transactions Transaction[]

  @@index([caseId])
  @@index([status])
}

model Transaction {
  id              String           @id @default(cuid())
  importId        String
  import          TransactionImport @relation(fields: [importId], references: [id], onDelete: Cascade)
  caseId          String

  // Core Data
  date        DateTime
  description String?      // Also known as: narration, particulars, details
  amount      Float
  type        TransactionType

  // Balance
  balance     Float?

  // Categorization
  counterparty   String?
  mode           TransactionMode @default(OTHER)
  referenceNumber String?  // Cheque number, UPI ID, reference, etc.

  // Import tracking
  rowNumber Int?
  rawData   Json?          // Original raw data for traceability

  // Risk (for MVP, simple risk tracking)
  riskScore   Float    @default(0)
  riskFactors String[] @default([])

  createdAt DateTime @default(now())

  // Relations
  redFlags RedFlag[]

  @@index([caseId])
  @@index([importId])
  @@index([date])
  @@index([type])
}

model RedFlagRule {
  id        String   @id @default(cuid())
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)

  name        String   // Rule name like "Large Transaction", "Structuring"
  description String   // Rule description
  isActive   Boolean  @default(true)
  priority   Int      @default(0) // Higher = more important

  // Rule parameters (stored as JSON for flexibility)
  parameters Json?    // e.g., { "minAmount": 100000, "maxAmount": 500000 }

  // Conditions
  conditionType  String?  // AMOUNT, FREQUENCY, PATTERN, etc.
  conditionValue String?  // Threshold value

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  redFlags RedFlag[]

  @@index([caseId])
}

model RedFlag {
  id        String   @id @default(cuid())
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  ruleId    String?
  rule      RedFlagRule? @relation(fields: [ruleId], references: [id])
  ruleName  String   // Denormalized rule name for quick display
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  // Flag details
  title       String          // Short title for the flag
  explanation String          // Explanation of why this was flagged
  severity    RedFlagSeverity @default(MEDIUM)

  // Investigation state
  status          InvestigationStatus @default(OPEN)
  reviewed        Boolean             @default(false)
  reviewedBy      String?
  reviewedAt      DateTime?

  // Feedback
  feedbackType  FeedbackType?
  feedbackNote  String?
  feedbackBy    User?   @relation(fields: [feedbackById], references: [id])
  feedbackById  String?
  feedbackAt    DateTime?

  // Audit trail
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  evidenceFiles   EvidenceFile[]
  feedbackHistory RedFlagFeedback[]
  investigationNotes InvestigationNote[]
  timeline        InvestigationTimeline[]

  @@index([caseId])
  @@index([transactionId])
  @@index([severity])
  @@index([status])
}

model RedFlagFeedback {
  id        String   @id @default(cuid())
  redFlagId String
  redFlag   RedFlag  @relation(fields: [redFlagId], references: [id], onDelete: Cascade)

  type      FeedbackType
  note      String?

  // User tracking
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([redFlagId])
  @@index([userId])
}

model InvestigationNote {
  id        String   @id @default(cuid())
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)

  // Content
  title     String   // Note title
  content   String   // Note content

  // Author
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])

  // Optional links to related entities
  transactionId String?
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  
  redFlagId     String?
  redFlag       RedFlag? @relation(fields: [redFlagId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([caseId])
  @@index([authorId])
  @@index([transactionId])
  @@index([redFlagId])
}

model EvidenceFile {
  id        String   @id @default(cuid())
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)

  // File info
  fileName     String
  originalName String
  mimeType     String
  size         Int      // File size in bytes
  path         String   // Storage path

  // Integrity hash (SHA256)
  hash        String   // SHA256 hash for evidence integrity

  // Description
  description String?
  category   String?   // DOCUMENT, SCREENSHOT, REPORT, etc.

  // Linked to transaction or red flag (optional)
  transactionId String?
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  
  redFlagId     String?
  redFlag       RedFlag?  @relation(fields: [redFlagId], references: [id], onDelete: SetNull)

  // Upload tracking
  uploadedById String
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])
  uploadedAt   DateTime @default(now())

  @@index([caseId])
  @@index([transactionId])
  @@index([redFlagId])
}

// Investigation timeline for audit trail
model InvestigationTimeline {
  id        String   @id @default(cuid())
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)

  // Reference to related entity
  redFlagId     String?
  redFlag       RedFlag? @relation(fields: [redFlagId], references: [id], onDelete: Cascade)

  transactionId String?
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  // Timeline entry
  eventType  TimelineEventType
  title      String
  description String?
  
  // User who performed the action
  userId     String
  user       User     @relation(fields: [userId], references: [id])

  // Optional metadata (JSON)
  metadata   Json?

  createdAt DateTime @default(now())

  @@index([caseId])
  @@index([redFlagId])
  @@index([transactionId])
  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
}