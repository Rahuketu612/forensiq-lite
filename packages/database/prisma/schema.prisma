// ForensiQ Lite - Prisma Database Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  AUDITOR
  VIEWER
}

enum CaseStatus {
  DRAFT
  ACTIVE
  UNDER_REVIEW
  CLOSED
}

enum TransactionType {
  CREDIT
  DEBIT
  TRANSFER
  REFUND
  FEE
  OTHER
}

enum TransactionMode {
  CASH
  CHEQUE
  NEFT
  RTGS
  UPI
  IMPS
  ONLINE
  CARD
  BANK
  OTHER
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  NEEDS_MANUAL_MAPPING
  MAPPING_CONFIRMED
  EXTRACTED_TEXT
  OCR_PENDING
  OCR_PROCESSING
  OCR_COMPLETED
  OCR_FAILED
}

enum RedFlagSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum InvestigationStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  FALSE_POSITIVE
}

enum TimelineEventType {
  FLAG_CREATED
  FLAG_REVIEWED
  FLAG_STATUS_CHANGED
  FLAG_FEEDBACK_ADDED
  NOTE_ADDED
  EVIDENCE_UPLOADED
  EVIDENCE_LINKED
  EVIDENCE_DELETED
  TRANSACTION_IMPORTED
  TRANSACTION_EXAMINED
  FUND_TRAIL_GENERATED
  TRANSACTION_LINK_CREATED
  TRANSACTION_LINK_DELETED
}

enum LinkReason {
  SAME_AMOUNT
  NEARBY_TIMESTAMP
  SAME_COUNTERPARTY
  NARRATION_SIMILARITY
  SAME_MODE
  SAME_TYPE
  ROUND_AMOUNT
  SUSPICIOUS_PATTERN
}

enum AuditAction {
  CREATED
  UPDATED
  DELETED
  READ
  LINK_CREATED
  LINK_DELETED
  TRAIL_GENERATED
  EXPORTED
}

model User {
  id                  String    @id @default(uuid())
  email               String    @unique
  name                String
  password            String
  role                UserRole  @default(AUDITOR)
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  passwordResetToken  String?
  passwordResetExpires DateTime?
  lastLoginAt         DateTime?
  lastLoginIp         String?

  casesCreated        Case[]                @relation("CreatedCases")
  casesAssigned       Case[]                @relation("AssignedCases")
  transactionImports  TransactionImport[]
  
  redFlagFeedbacks    RedFlagFeedback[]
  investigationNotes  InvestigationNote[]
  evidenceFiles       EvidenceFile[]
  timelines           InvestigationTimeline[]
  auditLogs           AuditLog[]
  transactionLinksCreated TransactionLink[]   @relation("LinkCreator")
  transactionLinksDeleted TransactionLink[]   @relation("LinkDeleter")

  @@index([email])
}

model AuditLog {
  id            String      @id @default(uuid())
  userId        String?
  action        AuditAction
  entityType    String
  entityId      String
  caseId        String?
  metadata      Json?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime    @default(now())

  user          User?       @relation(fields: [userId], references: [id])

  @@index([caseId])
  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
}

model Case {
  id              String     @id @default(uuid())
  caseNumber      String     @unique
  title           String
  description     String?
  status          CaseStatus @default(DRAFT)
  riskLevel       RiskLevel?
  clientName      String?
  clientEmail     String?
  clientPhone     String?
  clientAddress   String?
  assignedToId    String?
  assignedAt      DateTime?
  createdById     String
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  completedAt     DateTime?

  createdBy       User       @relation("CreatedCases", fields: [createdById], references: [id])
  assignedTo      User?      @relation("AssignedCases", fields: [assignedToId], references: [id])
  
  transactionImports TransactionImport[]
  transactions    Transaction[]
  redFlagRules   RedFlagRule[]
  redFlags       RedFlag[]
  investigationNotes InvestigationNote[]
  evidenceFiles  EvidenceFile[]
  timelines      InvestigationTimeline[]
  transactionLinks TransactionLink[]

  @@index([caseNumber])
  @@index([status])
  @@index([createdById])
}

model TransactionImport {
  id               String       @id @default(uuid())
  caseId           String
  fileName         String
  originalName     String
  mimeType         String
  importedById     String
  importedAt       DateTime     @default(now())
  status           ImportStatus @default(PENDING)
  totalRows        Int          @default(0)
  successRows      Int          @default(0)
  failedRows       Int          @default(0)
  errorLog         Json?
  hasText          Boolean      @default(false)
  extractedText    String?
  isScanned        Boolean      @default(false)
  ocrText          String?
  ocrConfidence    Float?
  ocrCompletedAt   DateTime?
  mappingConfig    Json?
  mappedBy         String?
  mappedAt         DateTime?

  case             Case         @relation(fields: [caseId], references: [id], onDelete: Cascade)
  importedBy       User         @relation(fields: [importedById], references: [id])
  transactions     Transaction[]

  @@index([caseId])
  @@index([status])
}

model Transaction {
  id              String           @id @default(uuid())
  importId        String
  caseId          String
  date            DateTime
  description     String?
  amount          Float
  type            TransactionType
  balance         Float?
  counterparty    String?
  mode            TransactionMode  @default(OTHER)
  referenceNumber String?
  rowNumber       Int?
  rawData         Json?
  riskScore       Float            @default(0)
  riskFactors     String[]         @default([])
  createdAt       DateTime         @default(now())

  import          TransactionImport @relation(fields: [importId], references: [id], onDelete: Cascade)
  case            Case              @relation(fields: [caseId], references: [id], onDelete: Cascade)
  
  redFlags        RedFlag[]
  investigationNotes InvestigationNote[]
  evidenceFiles   EvidenceFile[]
  timelines       InvestigationTimeline[]
  linksAsSource   TransactionLink[] @relation("SourceTransaction")
  linksAsTarget   TransactionLink[] @relation("TargetTransaction")

  @@index([caseId])
  @@index([importId])
  @@index([date])
  @@index([type])
}

model TransactionLink {
  id                 String      @id @default(uuid())
  caseId             String
  sourceTransactionId String
  targetTransactionId String
  linkReason         LinkReason
  confidenceScore    Float
  
  explanation        String

  amountMatch        Boolean?
  timestampMatch     Boolean?
  counterpartyMatch  Boolean?
  narrationMatch     Boolean?
  
  amountDifference   Float?
  timeDifferenceMs   Int?
  narrationSimilarity Float?
  
  createdById        String
  createdAt          DateTime    @default(now())
  deletedAt          DateTime?
  deletedById        String?

  case               Case        @relation(fields: [caseId], references: [id], onDelete: Cascade)
  sourceTransaction  Transaction @relation("SourceTransaction", fields: [sourceTransactionId], references: [id], onDelete: Cascade)
  targetTransaction  Transaction @relation("TargetTransaction", fields: [targetTransactionId], references: [id], onDelete: Cascade)
  createdBy          User        @relation("LinkCreator", fields: [createdById], references: [id])
  deletedBy          User?       @relation("LinkDeleter", fields: [deletedById], references: [id])

  @@index([caseId])
  @@index([sourceTransactionId])
  @@index([targetTransactionId])
  @@index([linkReason])
  @@index([confidenceScore])
  @@index([createdAt])
}

model RedFlagRule {
  id            String     @id @default(uuid())
  caseId        String
  name          String
  description   String
  isActive      Boolean    @default(true)
  priority      Int        @default(0)
  parameters    Json?
  conditionType String?
  conditionValue String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  case          Case       @relation(fields: [caseId], references: [id], onDelete: Cascade)
  redFlags      RedFlag[]

  @@index([caseId])
}

model RedFlag {
  id           String             @id @default(uuid())
  caseId       String
  ruleId       String?
  ruleName     String
  transactionId String
  title        String
  explanation  String
  severity     RedFlagSeverity    @default(MEDIUM)
  status       InvestigationStatus @default(OPEN)
  reviewed     Boolean            @default(false)
  reviewedBy   String?
  reviewedAt   DateTime?
  feedbackType String?
  feedbackNote String?
  feedbackById String?
  feedbackAt   DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  case         Case               @relation(fields: [caseId], references: [id], onDelete: Cascade)
  rule         RedFlagRule?       @relation(fields: [ruleId], references: [id])
  transaction  Transaction        @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  feedbacks    RedFlagFeedback[]
  investigationNotes InvestigationNote[]
  evidenceFiles EvidenceFile[]
  timelines    InvestigationTimeline[]

  @@index([caseId])
  @@index([transactionId])
  @@index([severity])
  @@index([status])
}

model RedFlagFeedback {
  id         String   @id @default(uuid())
  redFlagId  String
  type       String
  note       String?
  userId     String
  createdAt  DateTime @default(now())

  redFlag    RedFlag  @relation(fields: [redFlagId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id])

  @@index([redFlagId])
  @@index([userId])
}

model InvestigationNote {
  id            String    @id @default(uuid())
  caseId        String
  title         String
  content       String
  authorId      String
  transactionId String?
  redFlagId     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  case          Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  author        User      @relation(fields: [authorId], references: [id])
  transaction   Transaction? @relation(fields: [transactionId], references: [id])
  redFlag       RedFlag?  @relation(fields: [redFlagId], references: [id])

  @@index([caseId])
  @@index([authorId])
  @@index([transactionId])
  @@index([redFlagId])
}

model EvidenceFile {
  id            String    @id @default(uuid())
  caseId        String
  fileName      String
  originalName  String
  mimeType      String
  size          Int
  path          String
  hash          String
  description   String?
  category      String?
  transactionId String?
  redFlagId     String?
  uploadedById  String
  uploadedAt    DateTime  @default(now())

  case          Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  transaction   Transaction? @relation(fields: [transactionId], references: [id])
  redFlag       RedFlag?  @relation(fields: [redFlagId], references: [id])
  uploadedBy    User      @relation(fields: [uploadedById], references: [id])

  @@index([caseId])
  @@index([transactionId])
  @@index([redFlagId])
}

model InvestigationTimeline {
  id           String             @id @default(uuid())
  caseId       String
  redFlagId    String?
  transactionId String?
  eventType    TimelineEventType
  title        String
  description  String?
  userId       String
  metadata     Json?
  createdAt    DateTime           @default(now())

  case         Case               @relation(fields: [caseId], references: [id], onDelete: Cascade)
  redFlag      RedFlag?           @relation(fields: [redFlagId], references: [id])
  transaction  Transaction?      @relation(fields: [transactionId], references: [id])
  user         User               @relation(fields: [userId], references: [id])

  @@index([caseId])
  @@index([redFlagId])
  @@index([transactionId])
  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
}
