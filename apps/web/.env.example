# ===========================================
# ForensiQ Lite - Web Environment
# ===========================================

# ===========================================
# PORT ARCHITECTURE
# ===========================================
# Frontend (Next.js): 3000
# Backend API (NestJS): 3001
# PostgreSQL: 5432
# Future AI Service: 3002
# Future Worker/Queue: 3003
# Future OCR/Parser Service: 3004
# ===========================================

# API URL (must use NEXT_PUBLIC_ prefix for client-side access)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_API_PREFIX=api
NEXT_PUBLIC_API_VERSION=v1

# Application
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=ForensiQ Lite