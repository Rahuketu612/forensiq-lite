# ===========================================
# ForensiQ Lite - API Environment
# ===========================================

# Application
NODE_ENV=development
PORT=3001
API_PREFIX=api
npm_package_version=1.0.0

# Database (PostgreSQL)
DATABASE_URL=postgresql://forensiq:forensiq_secure_password@localhost:5432/forensiq?schema=public&sslmode=prefer

# PostgreSQL Connection
POSTGRES_USER=forensiq
POSTGRES_PASSWORD=forensiq_secure_password
POSTGRES_DB=forensiq
POSTGRES_PORT=5432
POSTGRES_HOST=localhost
POSTGRES_SYNC=true

# CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# JWT
JWT_SECRET=dev-secret-key-change-in-production-minimum-32-chars
JWT_EXPIRES_IN=7d

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads